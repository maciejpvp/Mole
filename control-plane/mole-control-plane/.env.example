PORT=8080

# PostgreSQL connection used by the control plane.
BLUEPRINT_DB_DATABASE=mole
BLUEPRINT_DB_USERNAME=mole
BLUEPRINT_DB_PASSWORD=replace-with-a-strong-password
BLUEPRINT_DB_HOST=127.0.0.1
BLUEPRINT_DB_PORT=5432
BLUEPRINT_DB_SCHEMA=public

# Private management API of the relay. The token must match
# MOLE_SERVER_API_TOKEN in server/.env.
TUNNEL_SERVER_URL=http://relay-private-address:9001
TUNNEL_SERVER_API_TOKEN=replace-with-a-long-random-secret
