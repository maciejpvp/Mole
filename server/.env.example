# Public relay identity and exposed ports.
MOLE_PUBLIC_HOST=relay.example.com
MOLE_CONTROL_PORT=9000
MOLE_API_LISTEN=:9001
MOLE_MANAGEMENT_PORT=9001
MOLE_TUNNEL_PORT_MIN=10000
MOLE_TUNNEL_PORT_MAX=10100

# Use a long, randomly generated value in a real deployment. This must match
# TUNNEL_SERVER_API_TOKEN in the control-plane environment.
MOLE_SERVER_API_TOKEN=replace-with-a-long-random-secret
MOLE_USAGE_SYNC_TOKEN=replace-with-the-same-long-random-secret

# Base URL the relay uses to report usage every five minutes.
MOLE_CONTROL_PLANE_URL=https://control.example.com
