# Shared secret — clients must supply this with --secret to connect.
# Generate a strong value, e.g.:  openssl rand -hex 32
MOLE_SECRET=change-me-to-a-strong-random-token

# Registry image to pull. Set this to your pushed image:
#   Docker Hub:  your-username/mole-server:latest
#   ECR:         123456789012.dkr.ecr.us-east-1.amazonaws.com/mole-server:latest
MOLE_IMAGE=maciekpvp/mole-server:latest

# Optional: override the default ports.
# CONTROL_PORT=9000
# PUBLIC_PORT=8000
